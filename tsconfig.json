{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "lib": ["DOM", "ES2022"],
    "types": ["node", "vitest/globals"],
    "paths": {
      "obsidian": ["tests/mocks/obsidian.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
